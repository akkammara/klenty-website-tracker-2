# Copy this to secrets.toml and fill in your values
# On Streamlit Cloud, add these in Settings > Secrets

PIPEDRIVE_API_KEY = "your-pipedrive-api-key"
PIPEDRIVE_DOMAIN = "klentysales"
PIPEDRIVE_FILTER_ID = "21551"

# Paste your GA4 service account JSON contents below
[ga4_credentials]
type = "service_account"
project_id = "your-project-id"
private_key_id = "your-key-id"
private_key = "-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
client_email = "your-service-account@project.iam.gserviceaccount.com"
client_id = "your-client-id"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
